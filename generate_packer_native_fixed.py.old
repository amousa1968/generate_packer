#!/usr/bin/env python3
"""
Packer HCL Generator for Platform9 Private Cloud OpenStack v1.1.3
Cinder Volume Support - ROOT LEVEL PARAMS (NOT block)
"""

import json
import argparse
import sys
from datetime import datetime
import os

def load_template_config(config_file="templates.json"):
    try:
        with open(config_file, 'r') as f:
            return json.load(f)
    except FileNotFoundError:
        print(f"Error: Configuration file '{config_file}' not found.")
        sys.exit(1)
    except json.JSONDecodeError as e:
        print(f"Error: Invalid JSON in '{config_file}': {e}")
        sys.exit(1)

def find_template_config_file(template_name, config_name, templates_dir="templates"):
    config_filename = f"{config_name}.json"
    for root, dirs, files in os.walk(templates_dir):
        if os.path.basename(root) == template_name and config_filename in files:
            return os.path.join(root, config_filename)
    return None

def load_template_vars(config_path):
    try:
        with open(config_path, 'r') as f:
            return json.load(f)
    except:
        return {}

def validate_templates(config, template_specs, templates_dir="templates"):
    available_templates = config['templates']
    valid_specs = []

    for template_name, config_name in template_specs:
        if template_name not in available_templates:
            print(f"Error: Unknown template: {template_name}")
            sys.exit(1)

        if not available_templates[template_name].get('enabled', True):
            print(f"Warning: Template '{template_name}' is disabled, skipping")
            continue

        config_path = find_template_config_file(template_name, config_name, templates_dir)
        if not config_path:
            print(f"Error: Configuration file not found for template '{template_name}'")
            sys.exit(1)

        valid_specs.append((template_name, config_name, config_path))

    return valid_specs

def get_ssh_public_key(template_name):
    """Read SSH public key from files/<template_name>/ directory"""
    possible_key_files = [
        os.path.join("files", template_name, "ssh_key.pub"),
        os.path.join("files", template_name, f"{template_name}-key.pub"),
        os.path.join("files", template_name, "key.pub"),
        os.path.join("files", "rocky97", "rocky-key.pub"),
    ]

    for key_file in possible_key_files:
        if os.path.exists(key_file):
            try:
                with open(key_file, 'r') as f:
                    key_content = f.read().strip()
                    print(f"[INFO] Found SSH public key: {key_file}")
                    return key_content
            except Exception as e:
                print(f"[WARNING] Could not read SSH key file {key_file}: {e}")

    print(f"[WARNING] No SSH public key found for template '{template_name}'")
    return None

def generate_header():
    return '''# Generated Packer Configuration for Platform9 PCD OpenStack - NATIVE VOLUME
# Boot VM from golden image + automatic blockstorage volume (/dev/vdb)
# Generated: ''' + datetime.now().strftime('%Y-%m-%d %H:%M:%S') + '''

# =============================================================================
# This file was generated by generate_packer.py
# Configuration: {config_name}
# =============================================================================

packer {
  required_plugins {
    openstack = {
      version = "1.1.3"
      source  = "github.com/hashicorp/openstack"
    }
  }
}

# =============================================================================
# Variables
# =============================================================================

# Platform9 PCD OpenStack credentials
variable "pcd_username" {
  type        = string
  sensitive   = true
  description = "Platform9 PCD OpenStack username"
}

variable "pcd_password" {
  type        = string
  sensitive   = true
  description = "Platform9 PCD OpenStack password"
}

variable "pcd_tenant" {
  type        = string
  sensitive   = true
  description = "Platform9 PCD OpenStack tenant/project name"
}

variable "pcd_auth_url" {
  type        = string
  default     = "https://disw-na-wiv.app.pcd.platform9.com/keystone/v3"
}

variable "openstack_path" {
  type        = string
  default     = "openstack"
  description = "Path to openstack CLI (including directory if needed)"
}

variable "vault_password" {
  type        = string
  sensitive   = true
}

variable "ssh_username" {
  type        = string
  default     = "rocky"
}

variable "ssh_password" {
  type        = string
  sensitive   = true
}

variable "ssh_public_key" {
  type        = string
  default     = ""
  description = "SSH public key for key-based authentication"
}

variable "jenkins_user_password" {
  type        = string
  sensitive   = true
}

variable "jenkins_user" {
  type        = string
  sensitive   = true
}

variable "ansible_branch" {
  type        = string
  default     = "main"
}

variable "ansible_repo_url" {
  type        = string
  default     = "https://gitlab.industrysoftware.automation.siemens.com/nnk1cf/agent_provisioning.git"
}

variable "git_sha" {
  type        = string
  default     = ""
}

# Volume Variables
variable "volume_size" {
  type        = number
  default     = 20
  description = "Size of the data volume in GB"
}

variable "volume_type" {
  type        = string
  default     = "synology"
  description = "Volume type for the storage"
}

variable "volume_name" {
  type        = string
  default     = "data-volume"
  description = "Base name for the created volume"
}

variable "vm_base_name" {
  type        = string
  default     = "rocky97"
  description = "Base name for the VM"
}
'''

def generate_locals(template_specs):
    locals_content = "locals {\n"
    for template_name, config_name, config_path in template_specs:
        local_name = f"{template_name}_{config_name}_config"
        config_path_forward = config_path.replace('\\', '/')
        locals_content += f'  {local_name} = jsondecode(file("{config_path_forward}"))\n'
    locals_content += "}\n\n"
    return locals_content

def generate_metadata_block(template_vars):
    default_metadata = {
        "assigned_to": "sim_devops@disw-na.local",
        "created_by": "SIM Team",
        "managed_by_group": "SIM Team",
        "product_segment": "IT"
    }

    template_metadata = template_vars.get('image_metadata', {})
    merged_metadata = {**default_metadata, **template_metadata}

    metadata_block = '  instance_metadata = {\n'
    for key, value in merged_metadata.items():
        metadata_block += f'    {key} = "{value}"\n'
    metadata_block += '  }\n'
    return metadata_block

def generate_user_data_template(ssh_username):
    """Generate cloud-init user_data template for SSH access + /dev/vdb volume"""
    template = '''#cloud-config
users:
  - name: __SSH_USERNAME__
    gecos: Demo User
    shell: /bin/bash
    groups: users,wheel,sudo
    passwd: "${var.ssh_password}"
    ssh_pwauth: True
    sudo: ["ALL=(ALL) NOPASSWD:ALL"]
    ssh_authorized_keys:
      - ${var.ssh_public_key}

ssh_pwauth: True

chpasswd:
  list: |
    __SSH_USERNAME__:${var.ssh_password}
  expire: False

package_update: true
package_upgrade: true

packages:
  - htop
  - git
  - ansible
  - xfsprogs

runcmd:
  - echo "VM customized with cloud-init + native volume /dev/vdb" >> /etc/motd
  - systemctl enable sshd
  - systemctl restart sshd
  - touch /tmp/cloud-init-ran.txt
  - [mkdir, -p, /mnt/mystuff]
  - [touch, /mnt/mystuff/testfile]

disk_setup:
  /dev/vdb:
    table_type: 'mbr'
    layout: 'auto'

fs_setup:
  - label: /mnt/inststg1
    filesystem: 'ext4'
    device: /dev/vdb1

mounts:
  - ["/dev/vdb1", "/mnt/inststg1"]
'''
    return template.replace('__SSH_USERNAME__', ssh_username)

def generate_sources_native(template_name, config_name, config_path, ssh_key=None):
    template_vars = load_template_vars(config_path)
    local_name = f"{template_name}_{config_name}_config"
    ssh_username = template_vars.get('ssh_username', 'rocky')

    security_groups_str = json.dumps(template_vars.get('security_groups', ["default"]))

    metadata_block = generate_metadata_block(template_vars)
    
    source_name = f"{template_name}_{config_name}"
    
    user_data = generate_user_data_template(ssh_username)

    source_config = f'''source "openstack" "{source_name}" {{
  image_name        = "${{local.{local_name}.vm_base_name}}-${{formatdate("YYYYMMDD-HHmmss", timestamp())}}"
  source_image_name = "${{local.{local_name}.golden_image_name}}"
  flavor            = "${{local.{local_name}.flavor}}"
  ssh_username      = "${{local.{local_name}.ssh_username}}"
  ssh_password      = var.ssh_password
  networks          = ["${{local.{local_name}.network}}"]
  security_groups   = {security_groups_str}
  region            = "${{local.{local_name}.region}}"
  identity_endpoint = var.pcd_auth_url
  tenant_name       = var.pcd_tenant
  username          = var.pcd_username
  password          = var.pcd_password
  domain_name       = "Default"
  ssh_timeout       = "30m"

  # ROOT LEVEL - OpenStack v1.1.3 Cinder Volume (NOT block)
  volume_size  = local.{local_name}.volume_size
  volume_type  = local.{local_name}.volume_type

  user_data = <<-EOF
{user_data}
EOF

{metadata_block}
}}

'''

    return source_config

def generate_build_block_native(template_name, config_name):
    source_name = f"{template_name}_{config_name}"
    return f'''build {{
  name = "{source_name}"
  sources = ["source.openstack.{source_name}"]
}}'''

def main():
    parser = argparse.ArgumentParser(description='Generate Packer HCL - OpenStack v1.1.3 Cinder Compatible')
    parser.add_argument('templates', nargs='*', help='Template name (e.g. rocky97)')
    parser.add_argument('--output', '-o', default='generated-native-fixed.pkr.hcl', help='Output HCL file')
    parser.add_argument('--list', action='store_true', help='List templates')

    args = parser.parse_args()
    
    if args.list:
        config = load_template_config()
        print("Templates:")
        for t, info in config['templates'].items():
            print(f"  {t} ({'enabled' if info.get('enabled') else 'disabled'})")
        return

    if not args.templates:
        print("Usage: python generate_packer_native_fixed.py rocky97 [--output file.pkr.hcl]")
        sys.exit(1)

    config = load_template_config()
    template_specs = [(t, 'vars') for t in args.templates]

    valid_specs = validate_templates(config, template_specs)
    
    header = generate_header()
    locals_content = generate_locals(valid_specs)

    source_configs = []
    build_configs = []

    for template_name, config_name, config_path in valid_specs:
        ssh_key = get_ssh_public_key(template_name)
        source = generate_sources_native(template_name, config_name, config_path, ssh_key)
        build = generate_build_block_native(template_name, config_name)
        source_configs.append(source)
        build_configs.append(build)

    hcl_content = header + locals_content + ''.join(source_configs) + ''.join(build_configs)

    with open(args.output, 'w') as f:
        f.write(hcl_content)

    print(f"✅ Generated {args.output}")
    print(f"✅ Test: packer validate -var-file=test.pkrvars.hcl {args.output}")
    print(f"✅ Build: packer build -var-file=test.pkrvars.hcl {args.output}")

if __name__ == '__main__':
    main()
