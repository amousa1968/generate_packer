# Generated Packer Configuration for Platform9 PCD OpenStack - NATIVE VOLUME
# Boot VM from golden image + automatic blockstorage volume (/dev/vdb)
# Generated: 2026-03-13 23:49:03

# =============================================================================
# This file was generated by generate_packer.py
# Configuration: {config_name}
# =============================================================================

packer {
  required_plugins {
    openstack = {
      version = "1.1.3"
      source  = "github.com/hashicorp/openstack"
    }
  }
}

# =============================================================================
# Variables
# =============================================================================

# Platform9 PCD OpenStack credentials
variable "pcd_username" {
  type        = string
  sensitive   = true
  description = "Platform9 PCD OpenStack username"
}

variable "pcd_password" {
  type        = string
  sensitive   = true
  description = "Platform9 PCD OpenStack password"
}

variable "pcd_tenant" {
  type        = string
  sensitive   = true
  description = "Platform9 PCD OpenStack tenant/project name"
}

variable "pcd_auth_url" {
  type        = string
  default     = "https://disw-na-wiv.app.pcd.platform9.com/keystone/v3"
}

variable "openstack_path" {
  type        = string
  default     = "openstack"
  description = "Path to openstack CLI (including directory if needed)"
}

variable "vault_password" {
  type        = string
  sensitive   = true
}

variable "ssh_username" {
  type        = string
  default     = "rocky"
}

variable "ssh_password" {
  type        = string
  sensitive   = true
}

variable "ssh_public_key" {
  type        = string
  default     = ""
  description = "SSH public key for key-based authentication"
}

variable "jenkins_user_password" {
  type        = string
  sensitive   = true
}

variable "jenkins_user" {
  type        = string
  sensitive   = true
}

variable "ansible_branch" {
  type        = string
  default     = "main"
}

variable "ansible_repo_url" {
  type        = string
  default     = "https://gitlab.industrysoftware.automation.siemens.com/nnk1cf/agent_provisioning.git"
}

variable "git_sha" {
  type        = string
  default     = ""
}

# Volume Variables
variable "volume_size" {
  type        = number
  default     = 20
  description = "Size of the data volume in GB"
}

variable "volume_type" {
  type        = string
  default     = "synology"
  description = "Volume type for the storage"
}

variable "volume_name" {
  type        = string
  default     = "data-volume"
  description = "Base name for the created volume"
}

variable "vm_base_name" {
  type        = string
  default     = "rocky97"
  description = "Base name for the VM"
}
locals {
  rocky97_vars_config = jsondecode(file("templates/rocky97/vars.json"))
}

source "openstack" "rocky97_vars" {
  image_name        = "${local.rocky97_vars_config.vm_base_name}-${formatdate("YYYYMMDD-HHmmss", timestamp())}"
  source_image_name = "${local.rocky97_vars_config.golden_image_name}"
  flavor            = "${local.rocky97_vars_config.flavor}"
  ssh_username      = "${local.rocky97_vars_config.ssh_username}"
  ssh_password      = var.ssh_password
  networks          = ["${local.rocky97_vars_config.network}"]
  security_groups   = ["default"]
  region            = "${local.rocky97_vars_config.region}"
  identity_endpoint = var.pcd_auth_url
  tenant_name       = var.pcd_tenant
  username          = var.pcd_username
  password          = var.pcd_password
  domain_name       = "Default"
  ssh_timeout       = "30m"

  # ROOT LEVEL - OpenStack v1.1.3 Cinder Volume (NOT block)
  volume_size  = local.rocky97_vars_config.volume_size
  volume_type  = local.rocky97_vars_config.volume_type

  user_data = <<-EOF
#cloud-config
users:
  - name: rocky
    gecos: Demo User
    shell: /bin/bash
    groups: users,wheel,sudo
    passwd: "${var.ssh_password}"
    ssh_pwauth: True
    sudo: ["ALL=(ALL) NOPASSWD:ALL"]
    ssh_authorized_keys:
      - ${var.ssh_public_key}

ssh_pwauth: True

chpasswd:
  list: |
    rocky:${var.ssh_password}
  expire: False

package_update: true
package_upgrade: true

packages:
  - htop
  - git
  - ansible
  - xfsprogs

runcmd:
  - echo "VM customized with cloud-init + native volume /dev/vdb" >> /etc/motd
  - systemctl enable sshd
  - systemctl restart sshd
  - touch /tmp/cloud-init-ran.txt
  - [mkdir, -p, /mnt/mystuff]
  - [touch, /mnt/mystuff/testfile]

disk_setup:
  /dev/vdb:
    table_type: 'mbr'
    layout: 'auto'

fs_setup:
  - label: /mnt/inststg1
    filesystem: 'ext4'
    device: /dev/vdb1

mounts:
  - ["/dev/vdb1", "/mnt/inststg1"]

EOF

  instance_metadata = {
    assigned_to = "sim_devops@disw-na.local"
    created_by = "SIM Team"
    managed_by_group = "SIM Team"
    product_segment = "IT"
  }

}

build {
  name = "rocky97_vars"
  sources = ["source.openstack.rocky97_vars"]
}